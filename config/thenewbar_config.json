{
    "rootUrl": "https://thenewbar.com",
    "baseUrl": "https://thenewbar.com/collections/all",
    "site_name": "thenewbar",
    "seller": "seller",
    "productsLinks": "/products/",
    "collectionLinks": "/collections/",
    "skipCollectionLinksInProducts": true,
    "moreConfig": true,
    "selectors": {
        "header": {
            "name": "meta[property='og:title']",
            "price": "meta[property='product:price:amount']",
            "currency": "meta[property='product:price:currency']",
            "images": "meta[property='og:image']"
        },
        "main": {
            "description": ".product-form__description"
        }
    },
    "pagination": {
        "type": "link",
        "selector": ".pagination__nav a[rel=\"next\"]"
    },
    "level": 1,
    "purePlayer": true
}