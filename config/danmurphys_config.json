{
    "rootUrl": "https://www.danmurphys.com.au",
    "baseUrl": "https://www.danmurphys.com.au/list/zero-alcohol-drinks",
    "site_name": "danmurphys",
    "seller": "seller",
    "productLinkAttribute": "href",
    "productLinkSelector": "li.js-list.search-results__item h2 a",
    "moreConfig": true,
    "selectors": {
        "header": {
            "description": "meta[property='og:description']",
            "images": "meta[property='og:image']"
        },
        "main": {
            "name": "h1.product-title .product-title__name",
            "price": ".pack__price-info .pack__price, .pack--selected .pack__price",
            "producer": "h1.product-title .product-title__brand"
        }
    },
    "pagination": {
        "type": "button",
        "selector": "button.infinite-loader__load-more-button"
    },
    "purePlayer": false,
    "level": 0
}