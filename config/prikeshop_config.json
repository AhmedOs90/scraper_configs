{
    "rootUrl": "https://prikeshop.lt",
    "baseUrl": "https://prikeshop.lt/product-category/other-drinks",
    "site_name": "prikeshop",
    "seller": "seller",
    "bannerSkip": "#button-age-check",
    "productsLinks": "/product/",
    "collectionLinks": "/product-category/",
    "skipCollectionLinksInProducts": true,
    "moreConfig": true,
    "selectors": {
        "header": {
            "images": "meta[property='og:image']"
        },
        "main": {
            "name": "#title",
            "description": ".short-description-text",
            "price": ".product-size-price .woocommerce-Price-amount",
            "energy": ".attribute-Energy",
            "sugar": ".attribute-Sugar",
            "producer": ".attribute-manufacturer_name"
        }
    },
    "extras": {
        "package": ".attribute-package",
        "amount_in_case": ".attribute-amount_in_case",
        "serving_suggestion": ".attribute-serving_suggestion",
        "size": ".attribute-size",
        "carbohydrates": ".attribute-Сarbohydrates",
        "ingredients": ".attribute-ingredients"
    },
    "pagination": {
        "type": "button",
        "selector": ".woocommerce-pagination button[data-type=\"products\"]"
    },
    "level": 0,
    "purePlayer": false
}